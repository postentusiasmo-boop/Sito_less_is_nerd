<article class="product-card"><a href="{{ product.url }}" aria-label="{{ product.title }}">{% if product.featured_image %}{{ product.featured_image | image_url: width: 700 | image_tag: class: 'product-image', loading: 'lazy', sizes: '(min-width: 900px) 25vw, 50vw' }}{% else %}<div class="product-image placeholder"></div>{% endif %}</a><div class="product-card-body"><h3><a href="{{ product.url }}">{{ product.title }}</a></h3><p>{% render 'price', product: product %}</p></div></article>
