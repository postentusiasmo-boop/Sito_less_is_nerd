<section class="pieces-section">
  {% for block in section.blocks %}
    {% assign collection = block.settings.collection %}
    {% assign title = block.settings.title | default: collection.title %}
    {% assign url = block.settings.link | default: collection.url | default: routes.all_products_collection_url %}

    <div class="piece-group" {{ block.shopify_attributes }}>
      <a class="collection-line" href="{{ url }}">
        <span>{{ 'collections.piece' | t }} {{ block.settings.label }}</span>
        <span class="collection-line-separator">_</span>
        <strong>{{ title }}</strong>
      </a>

      <div class="section piece-products">
        <div class="product-grid">
          {% for product in collection.products limit: section.settings.products_to_show %}
            {% render 'product-card', product: product %}
          {% else %}
            <div class="piece-empty">
              <p>{{ 'collections.empty' | t }}</p>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  {% endfor %}
</section>

{% schema %}
{
  "name": "Pieces",
  "settings": [
    { "type": "range", "id": "products_to_show", "label": "Products per piece", "min": 2, "max": 8, "step": 1, "default": 4 }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Piece",
      "settings": [
        { "type": "text", "id": "label", "label": "Numero", "default": "01" },
        { "type": "collection", "id": "collection", "label": "Collezione Shopify" },
        { "type": "text", "id": "title", "label": "Titolo manuale", "default": "Clark" },
        { "type": "url", "id": "link", "label": "Link manuale" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pieces",
      "blocks": [
        { "type": "collection", "settings": { "label": "01", "title": "Clark", "link": "/collections/clark" } },
        { "type": "collection", "settings": { "label": "02", "title": "New World", "link": "/collections/new-world" } }
      ]
    }
  ]
}
{% endschema %}
