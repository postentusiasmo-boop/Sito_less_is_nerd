<section class="collection-line-section">
  {% for block in section.blocks limit: 1 %}
    {% assign collection = block.settings.collection %}
    {% assign title = block.settings.title | default: collection.title %}
    {% assign url = block.settings.link | default: collection.url %}

    <a class="collection-line" href="{{ url | default: routes.all_products_collection_url }}" {{ block.shopify_attributes }}>
      <span>Piece {{ block.settings.label }}</span>
      <span class="collection-line-separator">_</span>
      <strong>{{ title }}</strong>
    </a>
  {% endfor %}
</section>

{% schema %}
{
  "name": "Pieces",
  "settings": [
    { "type": "text", "id": "heading", "label": "Titolo", "default": "Piece" }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Piece",
      "settings": [
        { "type": "text", "id": "label", "label": "Numero", "default": "01" },
        { "type": "collection", "id": "collection", "label": "Collezione Shopify" },
        { "type": "text", "id": "title", "label": "Titolo manuale", "default": "Clark" },
        { "type": "textarea", "id": "text", "label": "Testo", "default": "Identità quotidiane. Segni quasi invisibili." },
        { "type": "url", "id": "link", "label": "Link manuale" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pieces",
      "blocks": [
        {
          "type": "collection",
          "settings": {
            "label": "01",
            "title": "Clark",
            "link": "/collections/clark"
          }
        }
      ]
    }
  ]
}
{% endschema %}
