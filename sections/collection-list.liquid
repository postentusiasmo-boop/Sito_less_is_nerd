<section class="section collection-list-section">
  <div class="section-heading">
    <h2>{{ section.settings.heading }}</h2>
    {% if section.settings.link_label != blank %}
      <a class="text-link" href="{{ section.settings.link_url }}">{{ section.settings.link_label }}</a>
    {% endif %}
  </div>

  <div class="collection-list-grid">
    {% for block in section.blocks %}
      {% assign collection = block.settings.collection %}
      {% assign title = block.settings.title | default: collection.title %}
      {% assign text = block.settings.text | default: collection.description %}
      {% assign url = block.settings.link | default: collection.url %}

      <a class="collection-tile" href="{{ url | default: routes.all_products_collection_url }}" {{ block.shopify_attributes }}>
        <span>{{ block.settings.label }}</span>
        <h3>{{ title }}</h3>
        {% if text != blank %}
          <p>{{ text }}</p>
        {% endif %}
      </a>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Collezioni",
  "settings": [
    { "type": "text", "id": "heading", "label": "Titolo", "default": "Collezioni" },
    { "type": "text", "id": "link_label", "label": "Testo link", "default": "Tutte le collezioni" },
    { "type": "url", "id": "link_url", "label": "Link" }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collezione",
      "settings": [
        { "type": "text", "id": "label", "label": "Etichetta", "default": "01" },
        { "type": "collection", "id": "collection", "label": "Collezione Shopify" },
        { "type": "text", "id": "title", "label": "Titolo manuale", "default": "Supereroi" },
        { "type": "textarea", "id": "text", "label": "Testo", "default": "Icone, poteri e simboli ridotti all'essenziale." },
        { "type": "url", "id": "link", "label": "Link manuale" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collezioni",
      "blocks": [
        {
          "type": "collection",
          "settings": {
            "label": "01",
            "title": "Supereroi",
            "text": "Icone, poteri e simboli ridotti all'essenziale.",
            "link": "/collections/supereroi"
          }
        },
        {
          "type": "collection",
          "settings": {
            "label": "02",
            "title": "Console",
            "text": "Memorie da salotto, senza nostalgia urlata.",
            "link": "/collections/console"
          }
        },
        {
          "type": "collection",
          "settings": {
            "label": "03",
            "title": "Spazio",
            "text": "Rotte, pianeti e coordinate per chi sa guardare.",
            "link": "/collections/spazio"
          }
        }
      ]
    }
  ]
}
{% endschema %}
