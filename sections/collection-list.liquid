<section class="pieces-section">
  {% for block in section.blocks %}
    {% assign collection = block.settings.collection %}
    {% assign title = block.settings.title | default: collection.title %}
    {% assign url = block.settings.link | default: collection.url | default: routes.all_products_collection_url %}

    <div class="piece-group" {{ block.shopify_attributes }}>
      <div class="piece-inner">
        <div class="piece-image piece-image--{{ block.settings.image_ratio }}">
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 1800 | image_tag: loading: 'lazy', sizes: '(min-width: 900px) 1180px, 100vw' }}
          {% else %}
            <div class="piece-image-placeholder">
              <span>{{ title }}</span>
            </div>
          {% endif %}
        </div>

        <a class="piece-heading" href="{{ url }}">
          <span>{{ 'collections.piece' | t }} {{ block.settings.label }}</span>
          <strong>{{ title }}</strong>
        </a>

        <div class="piece-products">
          <div class="product-grid">
            {% for product in collection.products limit: section.settings.products_to_show %}
              {% render 'product-card', product: product %}
            {% else %}
              <div class="piece-empty">
                <p>{{ 'collections.empty' | t }}</p>
              </div>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  {% endfor %}
</section>

<style>
  .pieces-section {
    border-top: 1px solid var(--color-border);
  }

  .piece-group {
    padding: clamp(64px, 8vw, 108px) 24px;
  }

  .piece-group + .piece-group {
    border-top: 1px solid var(--color-border);
  }

  .piece-inner {
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .piece-image {
    width: 100%;
    margin-bottom: clamp(34px, 5vw, 64px);
    overflow: hidden;
    background: #f4f4f1;
  }

  .piece-image--landscape { aspect-ratio: 16 / 7; }
  .piece-image--wide { aspect-ratio: 2 / 1; }
  .piece-image--square { width: min(68%, 760px); aspect-ratio: 1; }

  .piece-image img,
  .piece-image-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .piece-image-placeholder {
    display: grid;
    place-items: center;
    border: 1px solid var(--color-border);
    color: #777;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
  }

  .piece-heading {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
    margin-bottom: 34px;
  }

  .piece-heading span {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
  }

  .piece-heading strong {
    font-size: clamp(48px, 8vw, 96px);
    font-weight: 800;
    line-height: .95;
  }

  .piece-empty {
    grid-column: 1 / -1;
    padding: 22px 0 40px;
    color: var(--color-muted);
  }

  @media (max-width: 620px) {
    .piece-group { padding: 52px 16px 64px; }
    .piece-image { margin-bottom: 34px; }
    .piece-image--landscape,
    .piece-image--wide { aspect-ratio: 4 / 3; }
    .piece-image--square { width: 100%; }
    .piece-heading { margin-bottom: 26px; }
    .piece-heading strong { font-size: clamp(46px, 16vw, 70px); }
  }
</style>

{% schema %}
{
  "name": "Pieces",
  "settings": [
    { "type": "range", "id": "products_to_show", "label": "Products per piece", "min": 2, "max": 8, "step": 1, "default": 4 }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Piece",
      "settings": [
        { "type": "text", "id": "label", "label": "Numero", "default": "01" },
        { "type": "collection", "id": "collection", "label": "Collezione Shopify" },
        { "type": "text", "id": "title", "label": "Titolo manuale", "default": "Clark" },
        { "type": "url", "id": "link", "label": "Link manuale" },
        { "type": "image_picker", "id": "image", "label": "Immagine collezione" },
        {
          "type": "select",
          "id": "image_ratio",
          "label": "Formato immagine",
          "default": "landscape",
          "options": [
            { "value": "landscape", "label": "Orizzontale" },
            { "value": "wide", "label": "Panoramica" },
            { "value": "square", "label": "Quadrata" }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pieces",
      "blocks": [
        { "type": "collection", "settings": { "label": "01", "title": "Clark", "link": "/collections/clark" } },
        { "type": "collection", "settings": { "label": "02", "title": "New World", "link": "/collections/new-world" } }
      ]
    }
  ]
}
{% endschema %}
