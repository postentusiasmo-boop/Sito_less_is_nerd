<section class="hero hero-editorial">
  <div class="hero-content">
    <h1>{{ section.settings.heading }}</h1>
    <p>{{ section.settings.text }}</p>
  </div>

  <div class="hero-media">
    {% if section.settings.image != blank %}
      {{ section.settings.image | image_url: width: 2000 | image_tag: loading: 'eager', sizes: '100vw' }}
    {% else %}
      <div class="hero-placeholder"></div>
    {% endif %}
  </div>
</section>

<style>
  .hero-editorial {
    display: flex;
    min-height: 0;
    flex-direction: column;
    overflow: visible;
    background: #fff;
  }

  .hero-editorial::after { content: none; }

  .hero-editorial .hero-content {
    order: 1;
    width: min(var(--max-width), calc(100% - 48px));
    margin: 0 auto;
    padding: clamp(72px, 9vw, 132px) 0 clamp(64px, 8vw, 112px);
    text-align: center;
  }

  .hero-editorial h1 {
    max-width: 920px;
    margin: 0 auto;
    font-size: clamp(48px, 9vw, 112px);
    text-align: center;
    text-shadow: none;
  }

  .hero-editorial .hero-content p:not(.eyebrow) {
    max-width: 560px;
    margin: 24px auto 0;
    color: #555;
    text-align: center;
    text-shadow: none;
  }

  .hero-editorial .hero-media {
    position: relative;
    inset: auto;
    z-index: auto;
    order: 2;
    width: 100%;
    background: #f7f7f5;
  }

  .hero-editorial .hero-media img,
  .hero-editorial .hero-placeholder {
    width: 100%;
    height: auto;
    min-height: 0;
    object-fit: contain;
  }

  .hero-editorial .hero-placeholder { aspect-ratio: 16 / 9; }

  @media (max-width: 620px) {
    .hero-editorial .hero-content {
      width: min(100% - 32px, 760px);
      padding: 54px 0 58px;
    }

    .hero-editorial h1 { font-size: clamp(44px, 13vw, 68px); }

    .hero-editorial .hero-content p:not(.eyebrow) {
      margin: 20px auto 0;
      text-align: center;
    }
  }
</style>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Siamo ciò che conosciamo." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Oggetti essenziali per chi si ritrova nei dettagli." }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
