<section class="hero"><div class="hero-media">{% if section.settings.image != blank %}{{ section.settings.image | image_url: width: 1800 | image_tag: loading: 'eager', sizes: '100vw' }}{% else %}<div class="hero-placeholder"></div>{% endif %}</div><div class="hero-content">{% if section.settings.eyebrow != blank %}<p class="eyebrow">{{ section.settings.eyebrow }}</p>{% endif %}<h1>{{ section.settings.heading }}</h1><p>{{ section.settings.text }}</p>{% if section.settings.button_label != blank %}<a class="button" href="{{ section.settings.button_link }}">{{ section.settings.button_label }}</a>{% endif %}</div></section>
{% schema %}{"name":"Hero","settings":[{"type":"image_picker","id":"image","label":"Image"},{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Less is nerd"},{"type":"text","id":"heading","label":"Heading","default":"Minimal graphics for maximum fandom"},{"type":"textarea","id":"text","label":"Text","default":"Prodotti essenziali per chi ama universi, codici, console e citazioni sottili."},{"type":"text","id":"button_label","label":"Button label","default":"Shop the drop"},{"type":"url","id":"button_link","label":"Button link"}],"presets":[{"name":"Hero"}]}{% endschema %}
