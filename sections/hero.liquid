<section class="hero hero-editorial">
  <div class="hero-media">
    {% if section.settings.image != blank %}
      {{ section.settings.image | image_url: width: 2000 | image_tag: loading: 'eager', sizes: '100vw' }}
    {% else %}
      <div class="hero-placeholder"></div>
    {% endif %}
  </div>

  <div class="hero-content">
    <h1>{{ section.settings.heading }}</h1>
    <p>{{ section.settings.text }}</p>
  </div>
</section>

<style>
  .hero-editorial {
    display: block;
    min-height: 0;
    overflow: visible;
    background: #fff;
  }

  .hero-editorial::after {
    content: none;
  }

  .hero-editorial .hero-media {
    position: relative;
    inset: auto;
    z-index: auto;
    width: 100%;
    background: #f7f7f5;
  }

  .hero-editorial .hero-media img,
  .hero-editorial .hero-placeholder {
    width: 100%;
    height: auto;
    min-height: 0;
    object-fit: contain;
  }

  .hero-editorial .hero-placeholder {
    aspect-ratio: 16 / 9;
  }

  .hero-editorial .hero-content {
    width: min(var(--max-width), calc(100% - 48px));
    margin: 0 auto;
    padding: clamp(64px, 8vw, 112px) 0 clamp(72px, 9vw, 128px);
    text-align: center;
  }

  .hero-editorial h1 {
    max-width: 920px;
    margin: 0 auto;
    font-size: clamp(48px, 9vw, 112px);
    text-shadow: none;
  }

  .hero-editorial p {
    max-width: 520px;
    margin: 24px auto 0;
    color: #555;
    text-shadow: none;
  }

  @media (max-width: 620px) {
    .hero-editorial .hero-media img {
      width: 100%;
      height: auto;
    }

    .hero-editorial .hero-content {
      width: min(100% - 32px, 760px);
      padding: 52px 0 72px;
      text-align: left;
    }

    .hero-editorial h1 {
      font-size: clamp(44px, 13vw, 68px);
    }

    .hero-editorial p {
      margin-left: 0;
      margin-right: 0;
    }
  }
</style>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Nerd, con misura." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Riferimenti precisi, forme pulite, nessun rumore." }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
