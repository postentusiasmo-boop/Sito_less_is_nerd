<section class="manifesto-section">
  <div class="manifesto-inner">
    {% if section.settings.kicker != blank %}<p class="eyebrow">{{ section.settings.kicker }}</p>{% endif %}
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.text }}</p>
    {% if section.settings.note != blank %}<span class="manifesto-note">{{ section.settings.note }}</span>{% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Manifesto",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Manifesto" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "No noise. Just recognition." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Un segno, una memoria, un codice privato. Se lo sai, basta." },
    { "type": "text", "id": "note", "label": "Note", "default": "Not merch. Signals." }
  ],
  "presets": [{ "name": "Manifesto" }]
}
{% endschema %}
