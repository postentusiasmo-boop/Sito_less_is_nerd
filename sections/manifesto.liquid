<section class="manifesto-section manifesto-section--compact">
  <div class="manifesto-inner">
    {% if section.settings.kicker != blank %}<p class="eyebrow">{{ section.settings.kicker }}</p>{% endif %}
    <h2>{{ section.settings.heading }}</h2>
    {% if section.settings.text != blank %}<p>{{ section.settings.text }}</p>{% endif %}
    {% if section.settings.principles != blank %}
      <span class="manifesto-divider" aria-hidden="true"></span>
      <p class="manifesto-principles">{{ section.settings.principles }}</p>
    {% endif %}
  </div>
</section>

<style>
  .manifesto-section--compact {
    padding-top: 0;
    padding-bottom: 0;
  }

  .manifesto-section--compact .manifesto-inner {
    padding-top: clamp(50px, 5.5vw, 68px);
    padding-bottom: clamp(50px, 5.5vw, 68px);
  }

  .manifesto-section--compact .manifesto-inner h2 {
    margin-bottom: 14px;
  }

  .manifesto-divider {
    display: block;
    width: 44px;
    height: 1px;
    margin: 24px auto 0;
    background: var(--color-text);
  }

  .manifesto-section--compact .manifesto-inner > p.manifesto-principles {
    margin: 30px auto 0;
    color: var(--color-text);
    font-size: clamp(13px, 1.4vw, 16px);
    font-weight: 700;
  }

  @media (max-width: 620px) {
    .manifesto-section--compact .manifesto-inner {
      padding-top: 44px;
      padding-bottom: 44px;
    }

    .manifesto-divider {
      margin-top: 20px;
    }

    .manifesto-section--compact .manifesto-inner > p.manifesto-principles {
      margin-top: 26px;
    }
  }
</style>

{% schema %}
{
  "name": "Manifesto",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Manifesto" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Proudly nerd." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "With style. Without the noise." },
    { "type": "text", "id": "principles", "label": "Principles", "default": "Clean _ Iconic _ Meaningful" }
  ],
  "presets": [{ "name": "Manifesto" }]
}
{% endschema %}
