<header class="site-header">
  {% if settings.announcement != blank %}
    <div class="announcement">{{ settings.announcement }}</div>
  {% endif %}

  <div class="header-inner">
    <a class="brand brand-logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }}" style="--logo-width: {{ settings.logo_width | default: 220 }}px">
      {% if settings.logo != blank %}
        {{ settings.logo | image_url: width: 1200 | image_tag: class: 'site-logo-image', widths: '180, 240, 360, 480, 720, 960, 1200', alt: shop.name }}
      {% else %}
        <img class="site-logo-image" src="{{ 'logo-default.png' | asset_url }}" alt="{{ shop.name }}" width="600" height="97">
      {% endif %}
    </a>

    <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="PrimaryNav">
      <span></span><span></span><span></span>
      <span class="visually-hidden">{{ 'general.menu' | t }}</span>
    </button>

    <nav id="PrimaryNav" class="primary-nav" aria-label="{{ 'general.primary_navigation' | t }}">
      {% for link in linklists.main-menu.links %}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {% else %}
        <a href="{{ routes.all_products_collection_url }}">{{ 'navigation.shop' | t }}</a>
        <a href="/collections">{{ 'navigation.collections' | t }}</a>
        <a href="/pages/about">{{ 'navigation.manifesto' | t }}</a>
        <a href="/pages/contact">{{ 'navigation.contact' | t }}</a>
      {% endfor %}

      {% if localization.available_languages.size > 1 or localization.available_countries.size > 1 %}
        {% form 'localization', id: 'MobileLocalization', class: 'mobile-localization-form' %}
          {% if localization.available_languages.size > 1 %}
            <label for="MobileLanguage">{{ 'localization.language' | t }}</label>
            <select id="MobileLanguage" name="locale_code" onchange="this.form.submit()">
              {% for language in localization.available_languages %}
                <option value="{{ language.iso_code }}"{% if language.iso_code == localization.language.iso_code %} selected{% endif %}>{{ language.endonym_name | capitalize }}</option>
              {% endfor %}
            </select>
          {% endif %}

          {% if localization.available_countries.size > 1 %}
            <label for="MobileCountry">{{ 'localization.country' | t }}</label>
            <select id="MobileCountry" name="country_code" onchange="this.form.submit()">
              {% for country in localization.available_countries %}
                <option value="{{ country.iso_code }}"{% if country.iso_code == localization.country.iso_code %} selected{% endif %}>{{ country.name }} · {{ country.currency.iso_code }}</option>
              {% endfor %}
            </select>
          {% endif %}
        {% endform %}
      {% endif %}
    </nav>

    <div class="header-actions">
      {% if localization.available_languages.size > 1 or localization.available_countries.size > 1 %}
        {% form 'localization', id: 'HeaderLocalization', class: 'localization-form' %}
          {% if localization.available_languages.size > 1 %}
            <label class="visually-hidden" for="HeaderLanguage">{{ 'localization.language' | t }}</label>
            <select id="HeaderLanguage" name="locale_code" onchange="this.form.submit()">
              {% for language in localization.available_languages %}
                <option value="{{ language.iso_code }}"{% if language.iso_code == localization.language.iso_code %} selected{% endif %}>{{ language.endonym_name | capitalize }}</option>
              {% endfor %}
            </select>
          {% endif %}

          {% if localization.available_countries.size > 1 %}
            <label class="visually-hidden" for="HeaderCountry">{{ 'localization.country' | t }}</label>
            <select id="HeaderCountry" name="country_code" onchange="this.form.submit()">
              {% for country in localization.available_countries %}
                <option value="{{ country.iso_code }}"{% if country.iso_code == localization.country.iso_code %} selected{% endif %}>{{ country.name }} · {{ country.currency.iso_code }}</option>
              {% endfor %}
            </select>
          {% endif %}
        {% endform %}
      {% endif %}

      <a class="cart-link" href="{{ routes.cart_url }}">
        {{ 'general.cart' | t }}
        <span class="cart-count">{{ cart.item_count }}</span>
      </a>
    </div>
  </div>
</header>

<style>
  .brand-logo {
    display: flex;
    align-items: center;
    width: min(var(--logo-width), 46vw);
    height: 74px;
    overflow: visible;
    line-height: 0;
  }

  .brand-logo .site-logo-image {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
    object-position: center;
  }

  .header-actions,
  .localization-form {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 8px;
  }

  .header-actions { min-width: 0; }
  .mobile-localization-form { display: none; }

  .localization-form select {
    width: auto;
    min-width: 0;
    min-height: 34px;
    padding: 6px 24px 6px 8px;
    border: 0;
    border-radius: 0;
    background-color: transparent;
    color: #111;
    font-size: 11px;
    font-weight: 600;
    cursor: pointer;
  }

  @media (max-width: 900px) {
    .brand-logo {
      width: min(var(--logo-width), 44vw);
      height: 64px;
    }
    .localization-form { display: none; }

    .mobile-localization-form {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 8px 12px;
      align-items: center;
      margin-top: 12px;
      padding-top: 18px;
      border-top: 1px solid var(--color-border);
      font-size: 12px;
      text-transform: none;
    }

    .mobile-localization-form select { min-height: 40px; }
  }
</style>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "text", "id": "brand_name", "label": "Brand name", "default": "Less is nerd" }
  ]
}
{% endschema %}
