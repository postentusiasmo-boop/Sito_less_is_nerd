<footer class="site-footer">
  <div class="footer-grid">
    <div>
      <div class="footer-logo" style="--logo-width: {{ settings.logo_width | default: 220 }}px">
        {% if settings.logo != blank %}
          {{ settings.logo | image_url: width: 1200 | image_tag: class: 'site-logo-image', widths: '180, 240, 360, 480, 720, 960, 1200', alt: shop.name }}
        {% else %}
          <img class="site-logo-image" src="{{ 'logo-default.png' | asset_url }}" alt="{{ shop.name }}" width="600" height="97">
        {% endif %}
      </div>
      <p>{{ section.settings.text }}</p>
    </div>

    <nav aria-label="Footer">
      {% for link in linklists.footer.links %}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {% else %}
        <a href="{{ routes.all_products_collection_url }}">{{ 'navigation.shop' | t }}</a>
        <a href="/collections">{{ 'navigation.collections' | t }}</a>
        <a href="/policies/shipping-policy">{{ 'navigation.shipping' | t }}</a>
        <a href="/policies/refund-policy">{{ 'navigation.returns' | t }}</a>
      {% endfor %}
    </nav>
  </div>

  <div class="footer-bottom">
    <span>&copy; {{ 'now' | date: '%Y' }} {{ section.settings.brand_name }}</span>
    <span>{{ 'general.powered_by_shopify' | t }}</span>
  </div>
</footer>

<style>
  .site-footer .footer-logo {
    width: min(var(--logo-width), 64vw);
    margin-bottom: 18px;
    line-height: 0;
  }

  .site-footer .site-logo-image {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
    object-position: left center;
  }
</style>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "brand_name", "label": "Brand name", "default": "Less is nerd" },
    { "type": "textarea", "id": "text", "label": "Footer text", "default": "Oggetti puliti, riferimenti precisi, nessun effetto speciale." }
  ]
}
{% endschema %}
