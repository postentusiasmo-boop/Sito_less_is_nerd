<section class="newsletter">
  <div>
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.text }}</p>
  </div>

  {% form 'customer', class: 'newsletter-form' %}
    <input type="hidden" name="contact[tags]" value="newsletter">
    <label class="visually-hidden" for="NewsletterEmail">{{ 'newsletter.email' | t }}</label>
    <input id="NewsletterEmail" type="email" name="contact[email]" placeholder="{{ 'newsletter.placeholder' | t }}" required>
    <button class="button" type="submit">{{ 'newsletter.submit' | t }}</button>
    {% if form.posted_successfully? %}
      <p class="form-message">{{ 'newsletter.success' | t }}</p>
    {% endif %}
    {% if form.errors %}
      <p class="form-message">{{ form.errors | default_errors }}</p>
    {% endif %}
  {% endform %}
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Private frequency" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "New pieces. Few words. Only when it matters." }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
