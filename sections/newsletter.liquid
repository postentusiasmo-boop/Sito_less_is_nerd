<section class="newsletter"><div><h2>{{ section.settings.heading }}</h2><p>{{ section.settings.text }}</p></div>{% form 'customer', class: 'newsletter-form' %}<input type="hidden" name="contact[tags]" value="newsletter"><label class="visually-hidden" for="NewsletterEmail">Email</label><input id="NewsletterEmail" type="email" name="contact[email]" placeholder="email@example.com" required><button class="button" type="submit">Entra</button>{% if form.posted_successfully? %}<p class="form-message">Grazie, iscrizione ricevuta.</p>{% endif %}{% if form.errors %}<p class="form-message">{{ form.errors | default_errors }}</p>{% endif %}{% endform %}</section>
{% schema %}{"name":"Newsletter","settings":[{"type":"text","id":"heading","label":"Heading","default":"Join the quiet side"},{"type":"textarea","id":"text","label":"Text","default":"Nuovi drop, grafiche limitate e riferimenti che capiranno solo le persone giuste."}],"presets":[{"name":"Newsletter"}]}{% endschema %}
