<section class="newsletter">
  <div>
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.text }}</p>
  </div>

  {% form 'customer', class: 'newsletter-form' %}
    <input type="hidden" name="contact[tags]" value="newsletter">
    <label class="visually-hidden" for="NewsletterEmail-{{ section.id }}">Email</label>
    <input id="NewsletterEmail-{{ section.id }}" type="email" name="contact[email]" placeholder="Email" required>
    <button class="button" type="submit">Join</button>
    {% if form.posted_successfully? %}<p class="form-message">You are in.</p>{% endif %}
    {% if form.errors %}<p class="form-message">{{ form.errors | default_errors }}</p>{% endif %}
  {% endform %}
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Private frequency" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Drop essenziali. Pochi messaggi." }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
