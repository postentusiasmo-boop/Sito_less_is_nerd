<section class="cart-page">
  <h1>Cart</h1>

  {% if cart.item_count > 0 %}
    <form action="{{ routes.cart_url }}" method="post" novalidate>
      <div class="cart-items">
        {% for item in cart.items %}
          <div class="cart-item">
            {% if item.image %}
              {{ item.image | image_url: width: 220 | image_tag: loading: 'lazy' }}
            {% endif %}
            <div>
              <h2>{{ item.product.title }}</h2>
              <p>{{ item.variant.title }}</p>
              <p>{{ item.final_line_price | money }}</p>
              <label for="updates_{{ item.key }}">Quantity</label>
              <input id="updates_{{ item.key }}" type="number" name="updates[]" value="{{ item.quantity }}" min="0">
            </div>
          </div>
        {% endfor %}
      </div>

      <div class="cart-summary">
        <p>Total: <strong>{{ cart.total_price | money }}</strong></p>
        <button class="button" type="submit" name="update">Update cart</button>
        <button class="button" type="submit" name="checkout">Checkout</button>
      </div>
    </form>
  {% else %}
    <p>Your cart is empty.</p>
    <a class="button" href="{{ routes.all_products_collection_url }}">Explore the shop</a>
  {% endif %}
</section>

{% schema %}
{
  "name": "Cart",
  "settings": []
}
{% endschema %}
