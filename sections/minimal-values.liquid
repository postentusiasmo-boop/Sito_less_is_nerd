<section class="values-section">
  {% if section.settings.heading != blank %}
    <div class="section-heading">
      <h2>{{ section.settings.heading }}</h2>
    </div>
  {% endif %}

  <div class="values-grid">
    {% for block in section.blocks %}
      <article class="value-card" {{ block.shopify_attributes }}>
        <span>{{ block.settings.label }}</span>
        <h3>{{ block.settings.heading }}</h3>
        <p>{{ block.settings.text }}</p>
      </article>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Minimal values",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Codice" }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "01" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Sottile" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Il riferimento c'è, ma non deve spiegarsi." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Minimal values",
      "blocks": [
        { "type": "value" },
        { "type": "value" },
        { "type": "value" }
      ]
    }
  ]
}
{% endschema %}
