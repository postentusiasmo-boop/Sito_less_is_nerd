<section class="values-section values-section--compact">
  {% if section.settings.heading != blank %}
    <p class="values-kicker">{{ section.settings.heading }}</p>
  {% endif %}

  <div class="values-line" aria-label="{{ section.settings.heading }}">
    {% for block in section.blocks %}
      <span {{ block.shopify_attributes }}>{{ block.settings.heading }}{% unless forloop.last %}.{% endunless %}</span>
    {% endfor %}
  </div>
</section>

<style>
  .values-section--compact {
    padding-top: clamp(54px, 7vw, 82px);
    padding-bottom: clamp(54px, 7vw, 82px);
  }

  .values-kicker {
    margin: 0 0 16px;
    color: var(--color-muted);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
  }

  .values-line {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0 .22em;
    font-size: clamp(40px, 7vw, 82px);
    font-weight: 800;
    line-height: 1;
  }

  @media (max-width: 620px) {
    .values-section--compact {
      padding-top: 46px;
      padding-bottom: 52px;
    }

    .values-line {
      font-size: clamp(36px, 11.5vw, 54px);
      line-height: 1.05;
    }
  }
</style>

{% schema %}
{
  "name": "Minimal values",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Codice" }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "01" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Semplice" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Minimal values",
      "blocks": [
        { "type": "value", "settings": { "heading": "Semplice" } },
        { "type": "value", "settings": { "heading": "Iconico" } },
        { "type": "value", "settings": { "heading": "Profondo" } }
      ]
    }
  ]
}
{% endschema %}
