<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_accent }}">
    <title>{{ page_title }}{%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}</title>
    {% if page_description %}<meta name="description" content="{{ page_description | escape }}">{% endif %}
    {{ content_for_header }}
    <style>:root{--color-background:{{ settings.color_background }};--color-text:{{ settings.color_text }};--color-accent:{{ settings.color_accent }};--color-surface:{{ settings.color_surface }};}</style>
    {{ 'theme.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'theme.js' | asset_url }}" defer></script>
  </head>
  <body class="template-{{ template.name }}">
    <a class="skip-link" href="#MainContent">Skip to content</a>
    {% section 'header' %}
    <main id="MainContent" role="main">{{ content_for_layout }}</main>
    {% section 'footer' %}
  </body>
</html>
